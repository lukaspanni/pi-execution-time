{
  "name": "pi-execution-time",
  "version": "0.1.0",
  "description": "Pi extension that shows prompt execution time in the footer while the agent works.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukaspanni/pi-execution-time"
  },
  "author": {
    "name": "Lukas Panni",
    "url": "https://github.com/lukaspanni"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "timer",
    "execution-time"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "validate": "npm run typecheck && npm run pack:check"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typescript": "^5.9.3"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
